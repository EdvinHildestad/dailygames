@page
@model DailyGames.Pages.Scores.AddModel
@{
    ViewData["Title"] = "Add Score";
}

<div class="container">
    <div class="row">
        <div class="col-md-6 offset-md-3">
            <h1 class="mb-4">📊 Add Game Score</h1>
            
            <div class="card">
                <div class="card-body">
                    <form method="post">
                        <div class="mb-3">
                            <label asp-for="ProfileId" class="form-label">Profile</label>
                            <select asp-for="ProfileId" class="form-select" required>
                                <option value="">Select a profile...</option>
                                @foreach (var profile in Model.Profiles)
                                {
                                    <option value="@profile.Id" selected="@(profile.Id == Model.ProfileId)">
                                        @profile.Name
                                    </option>
                                }
                            </select>
                        </div>

                        <div class="mb-3">
                            <label asp-for="GameType" class="form-label">Game</label>
                            <select asp-for="GameType" class="form-select" required>
                                @foreach (GameType gameType in Enum.GetValues<GameType>())
                                {
                                    var gameName = gameType switch
                                    {
                                        GameType.Wordle => "🔤 Wordle",
                                        GameType.Wordle_Norwegian => "🇳🇴 Wørdle",
                                        GameType.Worldle => "🌍 Worldle",
                                        GameType.Travle => "✈️ Travle",
                                        GameType.Bandle => "🎵 Bandle",
                                        _ => gameType.ToString()
                                    };
                                    <option value="@gameType" selected="@(gameType == Model.GameType)">
                                        @gameName
                                    </option>
                                }
                            </select>
                        </div>

                        <div class="mb-3">
                            <label asp-for="GameDate" class="form-label">Game Date</label>
                            <input asp-for="GameDate" type="date" class="form-control" required />
                        </div>

                        <div class="mb-3">
                            <div class="form-check">
                                <input asp-for="IsCompleted" class="form-check-input" type="checkbox" id="completedCheck" />
                                <label class="form-check-label" for="completedCheck">
                                    Game Completed Successfully
                                </label>
                            </div>
                        </div>

                        <div class="mb-3" id="triesSection">
                            <label asp-for="Tries" class="form-label">Number of Tries</label>
                            <input asp-for="Tries" type="number" class="form-control" min="1" max="20" placeholder="Enter number of tries..." />
                            <div class="form-text">How many attempts did it take to solve?</div>
                            <span asp-validation-for="Tries" class="text-danger"></span>
                        </div>

                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-primary">Add Score</button>
                            <a href="/" class="btn btn-secondary">Cancel</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', function() {
        const completedCheck = document.getElementById('completedCheck');
        const triesSection = document.getElementById('triesSection');
        const triesInput = document.querySelector('input[name="Tries"]');

        function toggleTriesSection() {
            if (completedCheck.checked) {
                triesSection.style.display = 'block';
                triesInput.required = true;
            } else {
                triesSection.style.display = 'none';
                triesInput.required = false;
                triesInput.value = '';
            }
        }

        completedCheck.addEventListener('change', toggleTriesSection);
        toggleTriesSection(); // Initial call
    });
</script>